# --- Database (local default) ---
# Local Docker Postgres (docker-compose.local.yml) maps 5434 -> 5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/finance_system

# Optional legacy source for migration/import scripts
# Example VM same host engine with separate DB:
LEGACY_DATABASE_URL=postgresql://root:CHANGE_ME@localhost:5432/finanzas

# --- API ---
API_HOST=0.0.0.0
API_PORT=4100
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://localhost:1420

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

# --- Desktop ---
VITE_API_BASE_URL=http://localhost:4100

# --- Copilot AI (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Auth (future) ---
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=change_me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL=
