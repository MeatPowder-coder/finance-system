{
  "name": "finance-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @finance-system/web dev",
    "dev:api": "pnpm --filter @finance-system/api dev",
    "dev:desktop": "pnpm --filter @finance-system/desktop dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose -f docker-compose.local.yml up -d",
    "db:down": "docker compose -f docker-compose.local.yml down",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:import:legacy": "node scripts/db-import-legacy.mjs",
    "bootstrap": "pnpm install && pnpm db:up && pnpm db:migrate"
  },
  "dependencies": {
    "pg": "^8.18.0"
  }
}
